# Umgebungsvariablen fuer den Portainer-Stack (stack.yml).
#
# - Portainer "Repository"-Methode: diese Datei wird aus dem Git-Repo gelesen.
# - Portainer "Web editor"/"Upload": Werte stattdessen im Portainer-Formular setzen
#   (dann wird stack.env von Portainer erzeugt).
#
# Keine Geheimnisse hier ablegen - die Datei liegt im (privaten) Git-Repo.

# Host-Port, unter dem der Dienst auf der NAS erreichbar ist (http://<NAS-IP>:HOST_PORT)
HOST_PORT=8080

# Abrufintervall der YouTube-RSS-Feeds in Minuten
POLL_MINUTES=30

# Zeitzone (fuer korrekte Zeitstempel/Logs)
TZ=Europe/Berlin

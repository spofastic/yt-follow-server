{
  "manifest_version": 3,
  "name": "YouTube Follow (Server-Client)",
  "version": "2.0.0",
  "description": "Folgt YouTube-Kanaelen per Klick und traegt sie in deinen zentralen yt-follow-Server ein (gemeinsame Liste mit PWA und iOS-Kurzbefehl).",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://www.youtube.com/*"],
  "optional_host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Follow"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
